{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "HarmonicaOS",
  "version": "0.1.0",
  "identifier": "com.harmonicaos.app",
  "build": {
    "beforeDevCommand": "npm run dev --workspace=apps/web",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build --workspace=apps/web",
    "frontendDist": "../../web/.next"
  },
  "app": {
    "title": "HarmonicaOS",
    "windows": [
      {
        "title": "HarmonicaOS",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' blob:; connect-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
